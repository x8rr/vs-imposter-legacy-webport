        "dialogue_sabotage7": "seni BOK PARÇASI!!!! sana ASLA güvenmemeliydim!!!",
        "dialogue_sabotage8": "YAPTIĞIN ŞEYİN BEDELİNİ SANA ÖDETECEĞİM",
        "dialogue_sabotage9": "SENİ DOĞDUĞUNA PİŞMAN ETTİRECEĞİM",
        "dialogue_sabotage10": "(burnunu çeker)..... intikamını alacağım bebeğim.....",
        "dialogue_sabotage11": "bitti mi?",
        "dialogue_sabotage12": "evet",
        "dialogue_meltdown0": "oooooooo ben bir hayaletiiim",
        "dialogue_meltdown1": "ben de ooooooo ooohoh",
        "dialogue_meltdown2": "AMKK KORKUTUCUSUN ",
        "dialogue_meltdown3": "evet... >:)",
        "dialogue_meltdown4": "ne yapacaksın lan PİÇ!!",
        "dialogue_meltdown5": "ö...özür dilerim.. sadece lütfen.. bana zarar vermeyin..",
        "dialogue_meltdown6": "evde kocam ve çocuklarım var....",
        "dialogue_meltdown7": "bir şey diyeyim mi.. tamam be. farklılıklarımızı bir kenara koyalım.",
        "dialogue_meltdown8": "beni ÖLDÜRDÜKTEN SONRA MI??? ne içtin sen???",
        "dialogue_meltdown9": "kokain",
        "dialogue_meltdown10": "ha mantıklı",
        "dialogue_toogus0": "abi o kırmızı eleman manyaktı, oradan canlı çıktığımız için mutluyum",
        "dialogue_toogus1": "canlı çıkmadık ki",
        "dialogue_toogus2": "Selam saygıdeğer dostlar!",
        "dialogue_toogus3": "... sen kimsin",
        "dialogue_toogus4": "ben sadece görevlerini yapmaya çalışan masum bir crewmate'im!",
        "dialogue_toogus5": "hmmmm boyfriend ben buna güvenemedim...",
        "dialogue_toogus6": "hadi be yahu! heyy hadi be hadi heyyy hadi",
        "dialogue_toogus7": "Hadi.",
        "dialogue_toogus8": "Ne dediğinin farkında mısın? sen KAFAYI SIYIRMIŞSIN.",
        "dialogue_toogus9": "aynen",
        "dialogue_toogus10": "tamam şimdi şarkı söyleyelim :)",
        "dialogue_lights0": "VOV tamam be... ben impostor'dum.",
        "dialogue_lights1": "biliyoruz",
        "dialogue_lights2": "planlarımı boşa çıkarmaya bayılıyorsunuz herhalde..",
        "dialogue_lights3": "evet koymuşuz geri zekalı?",
        "dialogue_lights4": "tamam şimdi benden kurtulmanız için bir toplantı başlatmanız gerekiyor",
        "dialogue_lights5": "ama siz bir işe yaramak yerine bip bop şarkılarınızı söylemeyi yeğlersiniz",
        "dialogue_lights6": "yani benim için kolay zafer",
        "dialogue_lights7": "senden daha iyi şarkı söylüyorum",
        "dialogue_lights8": "HAYIR SÖYLEMİYORSUN BAŞLAT ŞUNU",
        "dialogue_mando0": "oha selam dostlar!!",
        "dialogue_mando1": "şey merhaba..?",
        "dialogue_mando2": "selam??",
        "dialogue_mando3": "Among Us oynamaktan çok keyif alıyorum!",
        "dialogue_mando4": "şeyy.. tamam?",
        "dialogue_mando5": "hey neden öyle davranıyorsunuz :(",
        "dialogue_mando6": "yani bugün karşılaştığımız herkes bir İMPOSTOR çıkıp bizi öldürdü....",
        "dialogue_mando7": "oh. ",
        "dialogue_mando8": "bu biraz ırkçı değil mi ",
        "dialogue_mando9": "her among us aynı değildir",
        "dialogue_mando10": "haklısın özür dilerim",
        "dialogue_mando11": "her neyse görevleriniz neler?",
        "dialogue_mando12": "uhhhhh Rareblin'in \"Mando\" şarkısını söyle yazıyor",
        "dialogue_mando13": "ve emihead'in!",
        "dialogue_mando14": "harbi mi bende de öyle",
        "dialogue_mando15": "tamam",
        "dialogue_dlow0": "Vay be! B-bu baya keyifliydi! ^_^",
        "dialogue_dlow1": "düzgün konuşur musun",
        "dialogue_dlow2": "prdn",
        "dialogue_dlow3": "vay be bu eğlenceliydi!",
        "dialogue_dlow4": "şimdi bizi öldürecek misin",
        "dialogue_dlow5": "öldürmek mi?? hayır efendim ben asla öyle canice bir suç işlemem",
        "dialogue_dlow6": "yani cidden impostor değil misin..?",
        "dialogue_dlow7": "yani olsaydı bizi şu ana kadar öldürmüş olurdu",
        "dialogue_dlow8": "haklısın bebeğim, bu yüzden her gece bana çakmana izin veriyorum",
        "dialogue_dlow9": "sıradaki şarkı lütfen!",
        "dialogue_white0": "işte küçük gey arkadaşınız böyle gider",
        "dialogue_white1": "bu kabaydı",
        "dialogue_white2": "kaba bulup bulmaman sikimde değil",
        "dialogue_white3": "tanrım birbirimize bir keresine iyi davransak olmaz mı",
        "dialogue_white4": "evet katılıyorum, arkadaş olak mı beyaz?",
        "dialogue_white5": "valla mı?",
        "dialogue_white6": "hayır siktir git sdkjfhskd",
        "dialogue_white7": "vay be tamam o zaman.",
        "dialogue_ash0": "piç",
        "dialogue_ash1": "daha ağzımı bile açmadım",
        "dialogue_ash2": " sendeki piçliği sezebiliyorum !!",
        "dialogue_ash3": "erkek arkadaşımla düzgün konuşur musun.",
        "dialogue_ash4": "önce TAŞŞAKLARIMLA düzgün konuş!!!!",
        "dialogue_ash5": "şimdiden sinirimi bozmaya başladın",
        "dialogue_ash6": "biraz ATEŞ DAĞITMAMI izlemek ister misiniz?!?!?!",
        "dialogue_ash7": "bizi salmanı sağlar mı",
        "dialogue_ash8": "yoo",
        "dialogue_magma0": "haklıymışım GERÇEKTEN bir piçsin",
        "dialogue_magma1": "abi şu ÇENENİ KAPAR MISIN",
        "dialogue_magma2": "bir tane daha impostor'a katlanacak olursam kendimi burada vuracağım",
        "dialogue_magma3": "seni yüzünden bıçaklamama ne dersin",
        "dialogue_magma4": "sana şansını bile verdirmem",
        "dialogue_magma5": "aynen kanka",
        "dialogue_gray0": " ",
        "dialogue_gray1": "amanın",
        "dialogue_heartbeat0": "bu bahçede gerçekten yapayalnızım (arkadakileri görmezden gel)",
        "dialogue_heartbeat1": "acaba ne zaman yeni bir arkadaşım olacak....",
        "dialogue_heartbeat2": "asdghajdfkg ve sonra dedim ki",
        "dialogue_heartbeat3": "YUHH!!!! selaaaaaam!! sana el sallar",
        "dialogue_heartbeat4": "şey um senle konuşmuyordu",
        "dialogue_heartbeat5": "Bekle.. sen kimsin seni buralarda ilk kez görüyorum",
        "dialogue_heartbeat6": "selaaaaam benle arkadaş olur musun lütfeen lüyfen lüffen",
        "dialogue_heartbeat7": "ummm",
        "dialogue_heartbeat8": ":)",
        "dialogue_heartbeat9": "ummm uhh",
        "dialogue_heartbeat10": "<:)",
        "dialogue_heartbeat11": "olur",
        "dialogue_heartbeat12": "OLLLLEEEYY!!!",
        "dialogue_pinkwave0": "bir daha bir daha bir daha bir daha! bu şarkıya bayıldım lütfen bir daha söyleyelim!",
