        "dialogue_moogus6": "可疑...",
        "dialogue_moogus7": "喂我做了啥事 :(( 我是船員啊各位 :( 拜託 :((((",
        "dialogue_moogus8": "呃...這傢伙",
        "dialogue_moogus9": "你有把刀!!!!還有槍!!但只在你的向上動畫看得到!!!!",
        "dialogue_moogus10": "哇 :( 你倒是不用這麼雞掰 :(",
        "dialogue_moogus11": "隨便啦!來饒舌吧!",
        "dialogue_moogus12": "歐虧!",
        "dialogue_moogus13": "(呵...他們完全不知道我其實是偽裝者...)",
        "dialogue_moogus14": "我們聽得到你說話",
        "dialogue_sabotage0": "笑死!!!你這個智障!!!!!",
        "dialogue_sabotage1": "你上當了!!我其實這段時間都是偽裝者!!!! ",
        "dialogue_sabotage2": "ㄋ..妳....",
        "dialogue_sabotage3": "girlfriend....妳.....",
        "dialogue_sabotage4": "你怎麼能這樣做??!!",
        "dialogue_sabotage5": "為啥是她??!!",
        "dialogue_sabotage6": "寧願是我也不要是她!!!",
        "dialogue_sabotage7": "你這個混蛋!!!!我不應該信任你!!!",
        "dialogue_sabotage8": "我會讓你為你幹的事付出代價",
        "dialogue_sabotage9": "我會讓你後悔出生在這世界上",
        "dialogue_sabotage10": "抽泣.....我會替妳報仇寶貝.....",
        "dialogue_sabotage11": "好了沒?",
        "dialogue_sabotage12": "嗯",
        "dialogue_meltdown0": "嗚嗚哦哦哦我是鬼ㄟㄟㄟ",
        "dialogue_meltdown1": "我也是耶ㄝㄝ嗚嗚哦哦哦",
        "dialogue_meltdown2": "三小很可怕欸",
        "dialogue_meltdown3": "對啊... >:)",
        "dialogue_meltdown4": "你能怎樣賤逼!!",
        "dialogue_meltdown5": "我...我很抱歉...拜託...別傷害我...",
        "dialogue_meltdown6": "我老公跟小孩還在家等我...",
        "dialogue_meltdown7": "你知道嗎...好啊。我們把分歧放在一邊吧。",
        "dialogue_meltdown8": "在你殺死我之後???你嗑了什麼藥啊???",
        "dialogue_meltdown9": "大麻",
        "dialogue_meltdown10": "噢合理",
        "dialogue_toogus0": "剛剛那紅色傢伙真狂，幸好我們能夠活著逃走",
        "dialogue_toogus1": "我們明明都掛了",
        "dialogue_toogus2": "哈瞜各位船員們!",
        "dialogue_toogus3": "...你誰",
        "dialogue_toogus4": "我只是個在努力完成任務、毫無嫌疑的船員吶!",
        "dialogue_toogus5": "呃呃呃呃 bf 我不信任這傢伙...",
        "dialogue_toogus6": "噢拜託! 喂拜託各位拜託啦拜託",
        "dialogue_toogus7": "拜託。",
        "dialogue_toogus8": "你們要不要聽聽看你們在說什麼? 你們瘋了吧",
        "dialogue_toogus9": "行",
        "dialogue_toogus10": "那來唱歌唄 :)",
        "dialogue_lights0": "哇好啦... 我就是偽裝者。",
        "dialogue_lights1": "我們已經知道了",
        "dialogue_lights2": "你們就那麼愛擾亂我的計畫是吧...",
        "dialogue_lights3": "對ㄚ你能怎樣傻逼?",
        "dialogue_lights4": "反正你們要除掉我要先開個會",
        "dialogue_lights5": "但你這個智障寧願在那邊嗶嗶啵啵也不會做任何有用的事",
        "dialogue_lights6": "看來我贏定了",
        "dialogue_lights7": "我唱得比你好聽",
        "dialogue_lights8": "並沒有好嗎臭婊子",
        "dialogue_mando0": "OMG嗨朋友們!!",
        "dialogue_mando1": "你好...?",
        "dialogue_mando2": "嗨??",
        "dialogue_mando3": "我玩 Among Us 玩得很開心!",
        "dialogue_mando4": "嗯...好哦?",
        "dialogue_mando5": "欸欸你們還好嗎 :(",
        "dialogue_mando6": "就 我們目前遇到的每個人都是偽裝者 殺了我們...",
        "dialogue_mando7": "喔",
        "dialogue_mando8": "有點種族歧視我覺得",
        "dialogue_mando9": "不是所有的 among us 都一樣",
        "dialogue_mando10": "確實 抱歉",
        "dialogue_mando11": "你們有什麼任務哇?",
        "dialogue_mando12": "呃呃 唱 Rareblin 的 「 Mando 」",
        "dialogue_mando13": "還有 emihead!",
        "dialogue_mando14": "瓦草我也是耶",
        "dialogue_mando15": "行啊",
        "dialogue_dlow0": "哇! 真好玩! ^_^",
        "dialogue_dlow1": "講人話 謝謝",
        "dialogue_dlow2": "搜哩",
        "dialogue_dlow3": "哇 那首歌真酷!",
        "dialogue_dlow4": "所以你要殺我們了嗎",
        "dialogue_dlow5": "殺你們?? 我可不會犯如此逆天的罪呢",
        "dialogue_dlow6": "你真的不是偽裝者...?",
        "dialogue_dlow7": "她是的話應該早就殺我們了",
        "dialogue_dlow8": "好有道理啊寶貝 這就是為什麼我每天晚上都讓妳幹我",
        "dialogue_dlow9": "下一首!",
        "dialogue_white0": "看來你的奇葩朋友走了",
        "dialogue_white1": "你真的很沒禮貌",
        "dialogue_white2": "我他媽才不管妳覺得我怎樣勒",
        "dialogue_white3": "天啊為啥我們不能對彼此好一點呢",
        "dialogue_white4": "我同意，小白要當朋友嗎?",
        "dialogue_white5": "等等真的嗎?",
        "dialogue_white6": "笑死才不要",
        "dialogue_white7": "哇好吧。",
        "dialogue_ash0": "婊子",
        "dialogue_ash1": "沃草我什麼都還沒說欸",
        "dialogue_ash2": "我聞得到你身上的婊子味兒!!",
        "dialogue_ash3": "請對我男友禮貌一點。",
        "dialogue_ash4": "吃我雞巴!!!!",
        "dialogue_ash5": "你他媽怎麼已經那麼煩人了啊",
        "dialogue_ash6": "你們要不要聽我來段火的?!?!?!",
        "dialogue_ash7": "聽完之後你可以滾嗎",
        "dialogue_ash8": "不可以",
        "dialogue_magma0": "我鼻子果然很靈敏 你還真是個婊子",
        "dialogue_magma1": "你他媽可以閉嘴嗎",
        "dialogue_magma2": "我如果還需要在對付一個偽裝者我真的會吃掉一把槍管",
        "dialogue_magma3": "要不我先在你臉上插個孔 臭婊子",
        "dialogue_magma4": "我才不會讓你有機可乘呢",
        "dialogue_magma5": "行吧兄弟",
        "dialogue_gray0": " ",
        "dialogue_gray1": "天啊",
        "dialogue_heartbeat0": "哇 在這間溫室裡好孤單哦 (別理背景那些人)",
        "dialogue_heartbeat1": "我到底什麼時候才交得到朋友啊...",
        "dialogue_heartbeat2": "笑死 然後我就",
        "dialogue_heartbeat3": "歐買尬!!!!哈咿咿咿咿!!向你揮手",
        "dialogue_heartbeat4": "喔 他沒再跟你講話",
        "dialogue_heartbeat5": "等等...妳是誰我沒見過妳",
        "dialogue_heartbeat6": "嗨嗨要當我朋友嗎拜託拜託拜託",
        "dialogue_heartbeat7": "呃",
        "dialogue_heartbeat8": ":)",
        "dialogue_heartbeat9": "嗯呃",
        "dialogue_heartbeat10": "<:)",
        "dialogue_heartbeat11": "行",
        "dialogue_heartbeat12": "好耶耶耶耶耶耶耶!!!",
        "dialogue_pinkwave0": "再一次再一次再一次再一次!我喜歡那首歌可以再來一次嗎!",
        "dialogue_pinkwave1": "根據流程我們需要換下首歌 姐",
        "dialogue_pinkwave2": "噢!那下首應該會一樣好 :)",
        "dialogue_pinkwave3": "各位我剛發現...我們已經在這10分鐘了 沒人死掉耶",
        "dialogue_pinkwave4": "欸對耶...還有她好像不是偽裝者",
        "dialogue_pinkwave5": "該不對到最後沒有冒牌者在我們之中吧",
        "dialogue_pinkwave6": "可...可能吧!哈哈",
        "dialogue_pinkwave7": "...",
